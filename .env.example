# Server port
PORT=1279 # The fall of the Song Dynasty

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20
# Extra short-cycle limiter for API-Key endpoints; 429 here does not consume daily quota.
API_KEY_RATE_LIMIT_RPS=2
API_KEY_RATE_LIMIT_BURST=5

# Abuse protection
# IP/API Key blocklist is persisted in SQLite. Auto-block counts repeated 401/429 locally per process.
ABUSE_PROTECTION_ENABLED=true
ABUSE_AUTO_BLOCK_ENABLED=true
ABUSE_FAILURE_THRESHOLD=20
ABUSE_WINDOW_SECONDS=60
ABUSE_BLOCK_MINUTES=60

# Commercial API key auth
# Set to true when selling the enhanced query API.
API_AUTH_ENABLED=false
API_ADMIN_TOKEN=change-me-before-production
API_DEFAULT_DAILY_LIMIT=1000

# QanloAPI simplified billing flow
# Keep only QanloAPI entry. Do not expose app secrets in frontend/client packages.
QANLO_AGENT_BASE_URL=https://qanlo.com
QANLO_OPENAI_BASE_URL=https://qanlo.com/v1
QANLO_RECHARGE_URL=https://qanlo.com/purchase?compact=1&from=agent_key&tab=recharge&ui_mode=embedded
QANLO_AGENT_APP_ID=
QANLO_AGENT_NAME=chinese-poetry-api
QANLO_AGENT_MODEL=deepseek-v4-flash
QANLO_RETURN_URL=http://localhost:1279/api/v1/billing/qanlo/callback
QANLO_CALLBACK_SECRET=

# Optional server-side image generation for /api/v1/images/generate.
# This key stays on the server and is never exposed to the browser.
# Leave IMAGE_API_KEY empty to disable direct image generation without consuming quota.
IMAGE_API_KEY=
IMAGE_BASE_URL=https://qanlo.com/openai/v1
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=high
IMAGE_OUTPUT_FORMAT=png
IMAGE_TIMEOUT_SECONDS=180

# Optional: only needed when running `go run ./cmd/enrichment generate --provider qanlo`.
# Do not print this value in logs.
QANLO_AGENT_KEY=
